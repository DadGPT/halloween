# OPTIONAL. The app already ships with working public defaults baked into
# lib/supabase/env.ts, so it runs and deploys with no env vars at all.
# Set these only to point at a DIFFERENT Supabase project.
# (Project → Settings → API)

# Public — safe to expose to the browser (RLS-protected).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Server-only — NEVER expose. Reserved for future service-role admin features.
SUPABASE_SERVICE_ROLE_KEY=
