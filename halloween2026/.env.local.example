# Copy to .env.local and fill in from your Supabase project settings.
# (Project → Settings → API)

# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER expose. Used by route handlers for all writes/admin.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Simple shared passphrase to reach the admin dashboard (frictionless host login).
ADMIN_PASSCODE=change-me
